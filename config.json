SELECT query, calls, total_exec_time
FROM pg_stat_statements
WHERE query ILIKE '%ppd_swift%'
ORDER BY total_exec_time DESC
LIMIT 5;


-- Ile wierszy ma ta tabela?
SELECT COUNT(*) FROM ppd_kom;

-- Czy ma kolumnę daty?
SELECT column_name, data_type 
FROM information_schema.columns 
WHERE table_name = 'ppd_kom';



-- TOP 10 najcięższych zapytań (najwięcej czasu łącznie)
SELECT 
  LEFT(query, 100) AS query_preview,
  calls,
  ROUND(total_exec_time::numeric / 1000, 2) AS total_sec,
  ROUND(mean_exec_time::numeric, 2) AS avg_ms,
  ROUND(total_exec_time::numeric / sum(total_exec_time) OVER () * 100, 1) AS pct_total
FROM pg_stat_statements
ORDER BY total_exec_time DESC
LIMIT 10;


-- Zapytania robiące najwięcej seq scanów na ppd_kom i ppd_swift
SELECT 
  LEFT(query, 150) AS query_preview,
  calls,
  ROUND(mean_exec_time::numeric, 2) AS avg_ms,
  rows
FROM pg_stat_statements
WHERE query ILIKE '%ppd_kom%' 
   OR query ILIKE '%ppd_swift%'
ORDER BY calls DESC
LIMIT 10;



SELECT 
  tablename,
  indexname,
  idx_scan AS uzycia,
  pg_size_pretty(pg_relation_size(indexrelid)) AS rozmiar
FROM pg_stat_user_indexes
WHERE idx_scan = 0
  AND indexname NOT LIKE '%pkey%'
ORDER BY pg_relation_size(indexrelid) DESC;
